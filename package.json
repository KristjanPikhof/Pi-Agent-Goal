{
	"name": "pi-goal",
	"version": "0.1.5",
	"description": "Pi extension for branch-aware long-running /goal workflows.",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		},
		"./extensions": "./dist/extensions/index.js",
		"./package.json": "./package.json"
	},
	"scripts": {
		"typecheck": "tsc --noEmit",
		"lint": "eslint .",
		"format": "prettier --check .",
		"test": "vitest run",
		"build": "tsc -p tsconfig.publish.json && mkdir -p dist/extensions && printf 'export { default } from \"../index.js\";\\n' > dist/extensions/index.js",
		"build:publish": "rm -rf dist && npm run build",
		"prepack": "npm run build:publish"
	},
	"keywords": [
		"pi",
		"pi-extension",
		"goal",
		"pi-package"
	],
	"license": "UNLICENSED",
	"pi": {
		"extensions": [
			"./dist/extensions/index.js"
		]
	},
	"files": [
		"dist",
		"docs",
		"README.md"
	],
	"devDependencies": {
		"@eslint/js": "^9.39.1",
		"@types/node": "^24.10.1",
		"eslint": "^9.39.1",
		"prettier": "^3.6.2",
		"typescript": "^5.9.3",
		"typescript-eslint": "^8.46.3",
		"vitest": "^4.0.8"
	},
	"engines": {
		"node": ">=22.0.0"
	}
}
