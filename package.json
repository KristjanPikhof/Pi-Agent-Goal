{
  "name": "pi-goal-extension",
  "version": "0.1.0",
  "description": "Scaffold for a Pi /goal extension.",
  "type": "module",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "vitest run"
  },
  "keywords": [
    "pi",
    "pi-extension",
    "goal"
  ],
  "license": "UNLICENSED",
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "dependencies": {
    "@earendil-works/pi-coding-agent": "^0.74.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/node": "^24.10.1",
    "eslint": "^9.39.1",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.46.3",
    "vitest": "^4.0.8"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
